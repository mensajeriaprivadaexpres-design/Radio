<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
scroll-behavior:smooth;
}

body{
font-family:'Montserrat',sans-serif;
background:#050505;
color:white;
overflow-x:hidden;
}

/* HERO */

.hero{
position:relative;
height:100vh;
background:
linear-gradient(to bottom, rgba(0,0,0,.35), rgba(0,0,0,.88)),
url('https://images.unsplash.com/photo-1511512578047-dfb367046420?q=80&w=1800&auto=format&fit=crop') center center/cover no-repeat;
display:flex;
justify-content:center;
align-items:center;
text-align:center;
padding:20px;
overflow:hidden;
}

.glow-red{
position:absolute;
width:700px;
height:700px;
background:radial-gradient(circle, rgba(255,0,43,.28) 0%, rgba(0,0,0,0) 70%);
top:-220px;
right:-140px;
filter:blur(50px);
}

.glow-dark{
position:absolute;
width:500px;
height:500px;
background:radial-gradient(circle, rgba(255,255,255,.05) 0%, rgba(0,0,0,0) 70%);
bottom:-100px;
left:-100px;
filter:blur(45px);
}

.overlay{
position:absolute;
inset:0;
background:rgba(0,0,0,.28);
}

/* NAVBAR */

nav{
position:fixed;
top:0;
left:0;
width:100%;
padding:24px 60px;
display:flex;
justify-content:space-between;
align-items:center;
z-index:999;
background:rgba(0,0,0,.18);
backdrop-filter:blur(12px);
border-bottom:1px solid rgba(255,255,255,.05);
}

.logo{
font-size:18px;
font-weight:900;
letter-spacing:3px;
color:#ff233f;
text-transform:uppercase;
}

.menu{
display:flex;
gap:35px;
}

.menu a{
color:white;
text-decoration:none;
font-size:13px;
letter-spacing:4px;
opacity:.88;
transition:.3s;
}

.menu a:hover{
color:#ff233f;
}

/* HERO CONTENT */

.content{
position:relative;
z-index:5;
max-width:900px;
}

.live{
display:inline-block;
padding:12px 30px;
border-radius:50px;
background:rgba(255,35,63,.12);
border:1px solid rgba(255,35,63,.38);
letter-spacing:5px;
font-size:12px;
margin-bottom:35px;
box-shadow:0 0 25px rgba(255,35,63,.25);
}

h1{
font-size:clamp(62px,11vw,160px);
font-weight:900;
line-height:.88;
letter-spacing:4px;
text-transform:uppercase;
margin-bottom:18px;
}

.red{
color:#ff233f;
text-shadow:0 0 18px rgba(255,35,63,.35);
}

.tagline{
font-size:clamp(16px,2vw,24px);
letter-spacing:6px;
opacity:.82;
margin-bottom:48px;
}

.live-btn{
display:inline-flex;
align-items:center;
justify-content:center;
padding:20px 54px;
border-radius:60px;
background:#ff233f;
color:white;
text-decoration:none;
font-size:15px;
font-weight:700;
letter-spacing:4px;
transition:.35s;
box-shadow:
0 0 25px rgba(255,35,63,.35),
0 0 60px rgba(255,35,63,.15);
}

.live-btn:hover{
transform:translateY(-3px) scale(1.03);
background:#ff3d57;
}

/* SECTIONS */

section{
padding:110px 12%;
background:#080808;
border-top:1px solid rgba(255,255,255,.04);
}

section h2{
font-size:44px;
margin-bottom:28px;
color:#ff233f;
letter-spacing:2px;
}

section p{
max-width:850px;
line-height:1.9;
opacity:.82;
font-size:17px;
}

.playlist-btn{
margin-top:40px;
display:inline-flex;
padding:18px 40px;
border-radius:50px;
background:#161616;
border:1px solid rgba(255,255,255,.08);
text-decoration:none;
color:white;
letter-spacing:3px;
transition:.3s;
}

.playlist-btn:hover{
background:#ff233f;
}

.contact-links{
margin-top:35px;
display:flex;
flex-direction:column;
gap:18px;
}

.contact-links a{
color:white;
text-decoration:none;
font-size:18px;
opacity:.85;
}

.contact-links a:hover{
color:#ff233f;
}

/* FOOTER */

footer{
padding:35px;
text-align:center;
font-size:12px;
letter-spacing:4px;
background:black;
opacity:.55;
}

/* MOBILE */

@media(max-width:768px){

nav{
padding:20px;
flex-direction:column;
gap:18px;
}

.menu{
gap:18px;
flex-wrap:wrap;
justify-content:center;
}

.menu a{
font-size:11px;
}

.live-btn{
padding:18px 36px;
font-size:13px;
}

.tagline{
letter-spacing:3px;
}

}

</style>
</head>

